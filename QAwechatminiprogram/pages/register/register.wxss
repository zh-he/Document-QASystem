.register-container {
    padding: 40rpx;
    min-height: 100vh;
    background: #f8f9fa;
}

.register-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #2d3436;
    text-align: center;
    margin: 60rpx 0 80rpx;
    letter-spacing: 1.2rpx;
}

.form-item {
    margin-bottom: 40rpx;
    position: relative;
}

.form-item text {
    display: block;
    font-size: 28rpx;
    color: #636e72;
    margin-bottom: 16rpx;
}

input {
    width: 100%;
    height: 88rpx;
    padding: 0 24rpx;
    border: 2rpx solid #e9ecef;
    border-radius: 12rpx;
    font-size: 28rpx;
    background: #ffffff;
    transition: all 0.3s ease;
}

input:focus {
    border-color: #4dabf7;
    box-shadow: 0 4rpx 12rpx rgba(77, 171, 247, 0.1);
    outline: none;
}

input::placeholder {
    color: #adb5bd;
}

.password-strength {
    margin-top: 16rpx;
    font-size: 24rpx;
    color: #636e72;
}

.agreement-container {
    display: flex;
    align-items: center;
    margin: 40rpx 0;
}

.agreement-checkbox {
    margin-right: 16rpx;
}

.agreement-text {
    font-size: 26rpx;
    color: #636e72;
}

.agreement-link {
    color: #228be6;
    text-decoration: none;
}

.btn-register {
    width: 100%;
    height: 96rpx;
    line-height: 96rpx;
    background: linear-gradient(135deg, #4dabf7, #228be6);
    color: white;
    font-size: 32rpx;
    font-weight: 500;
    border-radius: 12rpx;
    margin-top: 40rpx;
    box-shadow: 0 4rpx 16rpx rgba(34, 139, 230, 0.3);
    transition: all 0.2s ease;
}

.btn-register:active {
    transform: scale(0.98);
    box-shadow: 0 2rpx 8rpx rgba(34, 139, 230, 0.3);
}

.login-link-container {
    margin-top: 40rpx;
    text-align: center;
    font-size: 26rpx;
    color: #636e72;
}

.btn-login-link {
    color: #228be6;
    margin-left: 16rpx;
    font-weight: 500;
    position: relative;
    transition: all 0.3s ease;
}

.btn-login-link::after {
    content: '';
    position: absolute;
    bottom: -4rpx;
    left: 0;
    width: 0;
    height: 2rpx;
    background: #228be6;
    transition: width 0.3s ease;
}

.btn-login-link:active {
    color: #1971c2;
}

.btn-login-link:hover::after {
    width: 100%;
}