.modify-password-container {
    padding: 40rpx;
    min-height: 100vh;
    background: #f8f9fa;
  }
  
  /* 标题样式同步注册页 */
  .register-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #2d3436;
    text-align: center;
    margin: 60rpx 0 80rpx;
    letter-spacing: 1.2rpx;
  }
  
  /* 表单项样式同步 */
  .form-item {
    margin-bottom: 40rpx;
    position: relative;
  }
  
  .form-item text {
    display: block;
    font-size: 28rpx;
    color: #636e72;
    margin-bottom: 16rpx;
  }
  
  .form-item input {
    width: 100%;
    height: 88rpx;
    padding: 0 24rpx;
    border: 2rpx solid #e9ecef;
    border-radius: 12rpx;
    font-size: 28rpx;
    background: #ffffff;
    transition: all 0.3s ease;
    margin: 0 auto;
    box-sizing: border-box;
  }
  
  /* 输入框聚焦效果 */
  .form-item input:focus {
    border-color: #4dabf7;
    box-shadow: 0 4rpx 12rpx rgba(77, 171, 247, 0.1);
    outline: none;
  }
  
  /* placeholder颜色统一 */
  .form-item input::placeholder {
    color: #adb5bd;
  }
  
  /* 按钮样式同步 */
  .btn-register {
    width: 100%;
    height: 96rpx;
    line-height: 96rpx;
    background: linear-gradient(135deg, #4dabf7, #228be6);
    color: white;
    font-size: 32rpx;
    font-weight: 500;
    border-radius: 12rpx;
    margin-top: 40rpx;
    box-shadow: 0 4rpx 16rpx rgba(34, 139, 230, 0.3);
    transition: all 0.2s ease;
  }
  
  .btn-register:active {
    transform: scale(0.98);
    box-shadow: 0 2rpx 8rpx rgba(34, 139, 230, 0.3);
  }