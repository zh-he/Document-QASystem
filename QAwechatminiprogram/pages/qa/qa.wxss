/* 全局容器，使用 Flex 布局 */
.qa-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background-color: #f8f9fa;
    font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    position: relative;
  }
    
  /* 菜单按钮 */
  .menu-btn {
    position: fixed;
    top: 40rpx;
    left: 40rpx;
    width: 88rpx;
    height: 88rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #ffffff;
    border-radius: 16rpx;
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
    z-index: 100;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
    
  .menu-btn:active {
    transform: scale(0.95);
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  }
    
  .menu-icon {
    width: 44rpx;
    height: 5rpx;
    background-color: #2d3436;
    position: relative;
    border-radius: 4rpx;
  }
    
  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    width: 44rpx;
    height: 5rpx;
    background-color: #2d3436;
    left: 0;
    border-radius: 4rpx;
    transition: transform 0.3s ease;
  }
    
  .menu-icon::before {
    top: -12rpx;
  }
    
  .menu-icon::after {
    top: 12rpx;
  }
    
  /* 会话列表侧边栏 */
  .session-list {
    position: fixed;
    left: -100%;
    top: 0;
    width: 80%;
    max-width: 640rpx;
    height: 100%;
    background-color: #ffffff;
    box-shadow: 8rpx 0 48rpx rgba(0, 0, 0, 0.12);
    z-index: 1000;
    transition: left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 120rpx 40rpx 80rpx;
    box-sizing: border-box;
    overflow-y: auto;
    border-top-right-radius: 16rpx;
    border-bottom-right-radius: 16rpx;
  }
    
  .session-list.show {
    left: 0;
  }
    
  .session-header {
    font-size: 40rpx;
    font-weight: 600;
    color: #2d3436;
    margin-bottom: 50rpx;
    padding-bottom: 20rpx;
    border-bottom: 2rpx solid #e9ecef;
  }
    
  .sessions-container {
    margin-top: 40rpx;
    padding-bottom: 40rpx;
  }
    
  .session-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28rpx 24rpx;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    position: relative;
    background-color: #f5f5f5;
    transition: all 0.2s ease;
  }
    
  .session-item:active {
    background-color: #eaeaea;
    transform: scale(0.99);
  }
    
  .session-item.active {
    background-color: #e0e0e0;
    font-weight: 500;
  }
    
  .session-title {
    font-size: 32rpx;
    color: #2d3436;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
    
  .session-actions {
    position: relative;
    display: flex;
    align-items: center;
  }
    
  .btn-more {
    width: 52rpx;
    height: 52rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #ced5db;
    border-radius: 50%;
    transition: background-color 0.2s ease;
    z-index: 10; /* 确保按钮在菜单上方 */
  }
    
  .btn-more:active {
    background-color: #84898d;
  }
    
  .more-icon {
    font-size: 36rpx;
    color: #ffffff;
    line-height: 1;
  }
    
  /* 操作菜单 - 极简定位 */
  .actions-menu {
    position: absolute;
    top: -90rpx; /* 固定位置在按钮上方 */
    right: 60rpx; /* 固定位置在按钮右侧 */
    background-color: #ffffff;
    border-radius: 16rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.25);
    z-index: 9999;
    min-width: 180rpx;
    display: none; /* 默认不显示 */
  }
  
  .actions-menu.show {
    display: block; /* 显示时直接切换显示方式，没有过渡动画 */
  }
  
  /* 菜单项样式 */
  .action-item {
    padding: 30rpx 28rpx;
    font-size: 30rpx;
    color: #2d3436;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }
  
  .action-item:active {
    background-color: #f1f3f5;
  }
  
  .rename-action {
    border-bottom: 1rpx solid #e9ecef;
  }
  
  .delete-action {
    color: #e74c3c;
  }
    
  .new-session {
    padding: 0 20rpx;
    margin-top: 40rpx;
    margin-bottom: 20rpx;
    height: 90rpx;
  }
    
  .btn-create {
    width: 100%;
    padding: 28rpx 0;
    background: linear-gradient(135deg, #4dabf7, #228be6);
    color: #ffffff;
    font-size: 34rpx;
    font-weight: 500;
    border-radius: 16rpx;
    text-align: center;
    box-shadow: 0 10rpx 24rpx rgba(34, 139, 230, 0.25);
    transition: all 0.2s ease;
  }
    
  .btn-create:active {
    transform: scale(0.98);
    box-shadow: 0 4rpx 16rpx rgba(34, 139, 230, 0.2);
  }
    
  /* 遮罩层 */
  .mask {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.35);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    backdrop-filter: blur(3px); /* 添加毛玻璃效果 */
  }
    
  .mask.show {
    opacity: 1;
    visibility: visible;
  }
    
  /* 聊天区域 - 修改为常规容器 */
  .chat-window {
    flex: 1;
    background-color: #f8f9fa;
    padding-top: 100rpx; /* 为顶部菜单按钮预留空间 */
    padding-bottom: 100rpx; /* 为底部输入框预留更多空间，确保最后一条消息可见 */
    box-sizing: border-box;
  }
    
  /* 消息列表容器 - 不再使用scroll-view */
  .messages-container {
    padding: 0 40rpx;
    background-color: #f8f9fa;
    min-height: calc(100vh - 240rpx);
  }
  
  /* 锚点，用于滚动定位和底部间距 */
  .message-anchor {
    height: 150rpx; /* 增加底部空间，防止最后一条消息被输入框遮挡 */
    margin-top: 40rpx;
  }
    
  /* 空状态提示 */
  .empty-state {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #adb5bd;
    font-size: 32rpx;
    margin-top: 100rpx;
    height: 300rpx;
  }
    
  /* 消息外层容器 */
  .msg-wrapper {
    width: 100%;
    display: flex;
    margin-bottom: 40rpx;
    opacity: 0;
    animation: fadeIn 0.3s forwards;
  }
    
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10rpx); }
    to { opacity: 1; transform: translateY(0); }
  }
    
  .msg-wrapper.user {
    justify-content: flex-end;
  }
    
  .msg-wrapper.bot,
  .msg-wrapper.assistant {
    justify-content: flex-start;
  }
    
  /* 消息气泡 */
  .msg-item {
    max-width: 85%;
    padding: 24rpx 32rpx;
    border-radius: 24rpx;
    word-break: break-word;
    box-sizing: border-box;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
    
  .msg-item.user {
    background: linear-gradient(135deg, #a5e3ff, #e1f5fe);
    border-top-right-radius: 8rpx;
    color: #0277bd;
  }
    
  .msg-item.assistant {
    background-color: #ffffff;
    border-top-left-radius: 8rpx;
    color: #343a40;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  }
    
  /* 气泡文字 */
  .msg-content {
    font-size: 26rpx;
    line-height: 1.6;
  }
    
  /* Loading 动画 */
  .loading {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 20rpx 40rpx;
    padding-left: 72rpx;
    margin-top: 20rpx;
    margin-bottom: 40rpx;
  }
    
  .dot-typing {
    width: 16rpx;
    height: 16rpx;
    background-color: #adb5bd;
    border-radius: 50%;
    animation: dot-typing 1.5s infinite linear;
    position: relative;
  }
    
  .dot-typing::before,
  .dot-typing::after {
    content: '';
    position: absolute;
    width: 16rpx;
    height: 16rpx;
    background-color: #adb5bd;
    border-radius: 50%;
    animation: dot-typing 1.5s infinite linear;
  }
    
  .dot-typing::before {
    left: -24rpx;
    animation-delay: 0s;
  }
    
  .dot-typing::after {
    left: 24rpx;
    animation-delay: 0.75s;
  }
    
  @keyframes dot-typing {
    0%, 100% {
      opacity: 0.3;
      transform: scale(0.7);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
  }
    
  /* 输入区域 */
  .input-area {
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    padding: 20rpx 25rpx;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
    background-color: #ffffff;
    border-top: 1rpx solid #e9ecef;
    box-sizing: border-box;
    z-index: 95;
    box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  }
    
  .input-wrapper {
    display: flex;
    align-items: flex-end;
    width: 100%;
    background-color: #f8f9fa;
    border: 1rpx solid #e9ecef;
    border-radius: 40rpx;
    box-sizing: border-box;
    padding: 12rpx 15rpx;
    transition: all 0.2s ease;
  }
    
  /* 文本输入框 */
  .msg-input {
    flex: 1;
    min-height: 68rpx; /* 初始高度 */
    max-height: 180rpx; /* 最大高度 */
    height: auto; /* 允许自动增长 */
    line-height: 1.5;
    padding: 15rpx 20rpx;
    border: none;
    background-color: transparent;
    font-size: 26rpx;
    color: #333;
    overflow-y: auto; /* 达到最大高度后可滚动 */
    word-break: break-word;
    transition: height 0.2s ease; /* 平滑过渡效果 */
  }
    
  /* 操作区域 */
  .action-area {
    display: flex;
    align-items: center;
    margin-left: 10rpx;
    padding-bottom: 10rpx; /* 添加底部间距使其与输入框对齐 */
  }
    
  /* 模式按钮 */
  .mode-btn {
    padding: 10rpx 18rpx;
    margin-right: 12rpx;
    background-color: #f0f2f5;
    border-radius: 20rpx;
    transition: background-color 0.2s;
  }
    
  .mode-btn:active {
    background-color: #e4e7eb;
  }
    
  .mode-text {
    font-size: 26rpx;
    color: #228be6;
    font-weight: 500;
  }
    
  /* 发送按钮 - 蓝色圆形风格 */
  .btn-send {
    width: 68rpx;
    height: 68rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #4dabf7, #228be6);
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4rpx 12rpx rgba(34, 139, 230, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
    
  .btn-send:active {
    transform: scale(0.92);
    box-shadow: 0 2rpx 8rpx rgba(34, 139, 230, 0.2);
  }
    
  .send-icon {
    width: 0;
    height: 0;
    border-left: 12rpx solid transparent;
    border-right: 12rpx solid transparent;
    border-bottom: 20rpx solid #ffffff;
    transform: rotate(90deg) translateX(2rpx);
  }
    
  /* 模式选项下拉菜单 */
  .mode-options {
    position: absolute;
    bottom: 110%;
    right: 25rpx;
    width: 240rpx;
    background-color: #ffffff;
    border-radius: 16rpx;
    box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
    z-index: 100;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10rpx);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
    
  .mode-options.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
    
  .mode-option {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx;
    font-size: 30rpx;
    color: #495057;
    transition: background-color 0.2s ease;
  }
    
  .mode-option:active {
    background-color: #f1f3f5;
  }
    
  .mode-option.active {
    background-color: #e7f5ff;
    color: #228be6;
    font-weight: 500;
  }
    
  .check-icon {
    width: 18rpx;
    height: 18rpx;
    border-radius: 50%;
    background-color: #228be6;
  }
  
  /* 删除返回底部按钮样式 */
  
  /* 空会话提示 */
  .empty-sessions {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 200rpx;
    color: #adb5bd;
    font-size: 30rpx;
  }

  .btn-send.disabled {
    opacity: 0.5;
    background: #a0a0a0;
    cursor: not-allowed;
  }