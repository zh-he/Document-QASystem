<view class="qa-container" bindtap="handlePageTap">

<!-- 菜单按钮 -->
<view class="menu-btn" catchtap="toggleSessionList">
  <view class="menu-icon"></view>
</view>

<!-- 会话列表侧边栏 -->
<view class="session-list {{showSessionList ? 'show' : ''}}">
  <view class="session-header">会话列表</view>
  <view class="sessions-container">
    <block wx:if="{{sessions.length > 0}}">
      <block wx:for="{{sessions}}" wx:key="id">
        <view class="session-item {{currentSessionId === item.id ? 'active' : ''}}"
              data-id="{{item.id}}"
              catchtap="selectSession">
          <text class="session-title">{{item.title || '未命名会话'}}</text>
          <view class="session-actions">
            <view class="btn-more" catchtap="showActionsMenu" data-index="{{index}}">
              <text class="more-icon">⋮</text>
            </view>
            <!-- 菜单在每个会话项目内直接显示，不使用任何定位 -->
            <view class="actions-menu {{activeMenuIndex === index ? 'show' : ''}}">
              <view class="action-item rename-action"
                    catchtap="renameSession" 
                    data-id="{{item.id}}">
                重命名
              </view>
              <view class="action-item delete-action"
                    catchtap="deleteSession" 
                    data-id="{{item.id}}">
                删除
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
    <block wx:else>
      <view class="empty-sessions">
        <text>暂无会话记录</text>
      </view>
    </block>
  </view>
  <view class="new-session">
    <view class="btn-create" bindtap="createNewSession">
      <text>新建会话</text>
    </view>
  </view>
</view>

<!-- 遮罩层 -->
<view class="mask {{showSessionList ? 'show' : ''}}" bindtap="toggleSessionList"></view>

<!-- 聊天区域 - 移除scroll-view，使用页面自然滚动 -->
<view class="chat-window">
  <view class="messages-container">
    <block wx:if="{{messages.length > 0}}">
      <block wx:for="{{messages}}" wx:key="index">
        <view id="msg-{{index}}" class="msg-wrapper {{item.role}}">
          <view class="msg-item {{item.role}}">
            <view class="msg-content">{{item.content}}</view>
          </view>
        </view>
      </block>
      <view class="loading" wx:if="{{isLoading}}">
        <view class="dot-typing"></view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <text>开始一段新的对话吧</text>
    </view>
    
    <!-- 用于滚动定位和底部间距的锚点 -->
    <view id="message-anchor" class="message-anchor"></view>
  </view>
</view>

<!-- 输入区域 -->
<view class="input-area">
  <view class="input-wrapper">
    <textarea class="msg-input"
      style="height: {{textareaHeight}}rpx"
      placeholder="输入您的问题..."
      value="{{inputValue}}"
      bindinput="onInputChange"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      maxlength="-1"
      show-confirm-bar="{{false}}"
      cursor-spacing="20"
      auto-height="{{false}}"
      adjust-position="{{false}}"
      hold-keyboard="{{true}}"
    ></textarea>

    <view class="action-area">
      <!-- 模式选择器按钮 -->
      <view class="mode-btn" catchtap="toggleModeOptions" hover-class="btn-hover">
        <text class="mode-text">{{selectedMode}}</text>
      </view>
      
      <!-- 发送按钮 -->
      <view class="btn-send {{isLoading ? 'disabled' : ''}}" 
      catchtap="{{isLoading ? '' : 'sendMessage'}}" 
      hover-class="{{isLoading ? '' : 'btn-hover'}}">
        <view class="send-icon"></view>
      </view>
    </view>
  </view>
  
  <!-- 模式选项下拉菜单 -->
  <view class="mode-options {{showModeOptions ? 'show' : ''}}">
    <block wx:for="{{modes}}" wx:key="*this">
      <view class="mode-option {{selectedMode === item ? 'active' : ''}}"
            data-mode="{{item}}"
            catchtap="selectMode">
        <text>{{item}}</text>
        <view wx:if="{{selectedMode === item}}" class="check-icon"></view>
      </view>
    </block>
  </view>
</view>


</view>